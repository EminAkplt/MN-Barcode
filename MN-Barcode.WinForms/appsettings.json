    //  Integrated Security: Windows kimlik dogrulamasi (kullanici/sifre gerekmez)
    "DefaultConnection": "Data Source=.\\SQLEXPRESS; Initial Catalog=MNBarcodeLocal; Integrated Security=True; TrustServerCertificate=True;"
  }
}
