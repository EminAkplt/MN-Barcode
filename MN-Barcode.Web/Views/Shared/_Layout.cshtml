<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - MN Barcode</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
        <link href="~/css/layout.css" rel="stylesheet" />

        @await RenderSectionAsync("Styles", required: false)
    
</head>
<body>

    <div class="d-flex">

        <nav id="sidebar">
            <div class="sidebar-header">
                <h3><i class="fas fa-barcode"></i> MN-Pos</h3>
            </div>

            <ul class="list-unstyled components">

                <li>
                    <a href="/Home/Index"><i class="fas fa-home"></i> Özet Ekran</a>
                </li>

                <li>
                    <a href="#satisSubmenu" data-bs-toggle="collapse" aria-expanded="false" class="dropdown-toggle">
                        <i class="fas fa-cash-register"></i> Satış İşlemleri
                    </a>
                    <ul class="collapse list-unstyled" id="satisSubmenu">
                        <li>
                            <a href="/Sales/Index"><i class="fas fa-play"></i> Hızlı Satış Ekranı</a>
                        </li>
                        <li>
                            <a href="/Sales/History"><i class="fas fa-history"></i> Satış Geçmişi</a>
                        </li>
                        <li>
                            <a href="/Sales/Returns"><i class="fas fa-undo"></i> İade İşlemleri</a>
                        </li>
                    </ul>
                </li>

                <li>
                    <a href="#urunSubmenu" data-bs-toggle="collapse" aria-expanded="false" class="dropdown-toggle">
                        <i class="fas fa-box-open"></i> Stok Yönetimi
                    </a>
                    <ul class="collapse list-unstyled" id="urunSubmenu">
                        <li>
                            <a href="/Product/Index"><i class="fas fa-list"></i> Ürün Listesi</a>
                        </li>
                        <li>
                            <a href="/Product/Add"><i class="fas fa-plus"></i> Yeni Ürün Ekle</a>
                        </li>
                        <li>
                            <a href="/Category/Index"><i class="fas fa-tags"></i> Kategoriler</a>
                        </li>
                    </ul>
                </li>

                <li>
                    <a href="/Report/Index"><i class="fas fa-chart-pie"></i> Raporlar</a>
                </li>

                <li>
                    <a href="/Expense/Index"><i class="fas fa-file-invoice-dollar"></i> Giderler</a>
                </li>

                <li>
                    <a href="/Settings/Index"><i class="fas fa-cogs"></i> Ayarlar</a>
                </li>
            </ul>

            <div class="text-center mt-5">
                <a href="/Account/Logout" class="btn btn-outline-danger btn-sm w-75">
                    <i class="fas fa-sign-out-alt"></i> Çıkış
                </a>
            </div>
        </nav>

        <div id="content">

            <nav class="navbar navbar-expand-lg navbar-light bg-light rounded shadow-sm mb-4">
                <div class="container-fluid">

                    <button type="button" id="sidebarCollapse" class="btn-toggle">
                        <i class="fas fa-bars"></i>
                    </button>

                    <div class="ms-auto d-flex align-items-center">
                        <span class="me-2 text-muted fw-bold">
                            @User.Identity.Name
                        </span>
                        <i class="fas fa-user-circle fa-2x text-secondary"></i>
                    </div>
                </div>
            </nav>

            @RenderBody()
        </div>

    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

    <script>
        document.addEventListener("DOMContentLoaded", function () {
            document.getElementById('sidebarCollapse').addEventListener('click', function () {
                document.getElementById('sidebar').classList.toggle('active');
            });
        });
    </script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>