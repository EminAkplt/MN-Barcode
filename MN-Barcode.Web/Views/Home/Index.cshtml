@{
    ViewData["Title"] = "Kontrol Paneli";
}

<div class="row">
    <div class="col-md-3">
        <div class="card bg-primary text-white p-3 mb-3 border-0 shadow-sm">
            <div class="d-flex justify-content-between align-items-center">
                <div>
                    <h6 class="mb-0">Günlük Ciro</h6>
                    <h3 class="fw-bold mb-0">₺ 0.00</h3>
                </div>
                <i class="fas fa-wallet fa-2x opacity-50"></i>
            </div>
        </div>
    </div>

    <div class="col-md-3">
        <div class="card bg-success text-white p-3 mb-3 border-0 shadow-sm">
            <div class="d-flex justify-content-between align-items-center">
                <div>
                    <h6 class="mb-0">Toplam Ürün</h6>
                    <h3 class="fw-bold mb-0">0 Adet</h3>
                </div>
                <i class="fas fa-boxes fa-2x opacity-50"></i>
            </div>
        </div>
    </div>

    <div class="col-md-3">
        <div class="card bg-warning text-dark p-3 mb-3 border-0 shadow-sm">
            <div class="d-flex justify-content-between align-items-center">
                <div>
                    <h6 class="mb-0">Kritik Stok</h6>
                    <h3 class="fw-bold mb-0">0</h3>
                </div>
                <i class="fas fa-exclamation-triangle fa-2x opacity-50"></i>
            </div>
        </div>
    </div>

    <div class="col-md-3">
        <div class="card bg-white text-dark p-3 mb-3 border-0 shadow-sm">
            <h6 class="text-muted">Hızlı İşlem</h6>
            <a href="#" class="btn btn-outline-primary w-100 btn-sm">
                <i class="fas fa-plus"></i> Yeni Ürün Ekle
            </a>
        </div>
    </div>
</div>

<div class="card border-0 shadow-sm mt-3" style="height: 400px;">
    <div class="card-body d-flex align-items-center justify-content-center text-muted">
        <div>
            <i class="fas fa-chart-area fa-3x mb-3 d-block text-center"></i>
            Satış Grafikleri Burada Olacak
        </div>
    </div>
</div>