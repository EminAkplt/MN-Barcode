@{
    Layout = null; /* Bu sayfa bağımsızdır, ana şablona (Layout) uymaz */
}

<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Giriş Yap - MN Barcode</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">

    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

    <link href="~/css/login.css" rel="stylesheet" />
</head>
<body>

    <div class="login-container">
        <div class="brand-logo">
            <i class="fas fa-boxes-stacked"></i> MN-Barcode
        </div>

        @if (ViewBag.Error != null)
        {
            <div class="alert alert-danger text-center p-2 mb-3">
                <i class="fas fa-exclamation-triangle me-2"></i> @ViewBag.Error
            </div>
        }

        <form action="/Account/Login" method="post">

            <div class="form-group">
                <label class="form-label text-muted small fw-bold">İŞLETME KODU</label>
                <div class="input-group">
                    <span class="input-group-text bg-white border-end-0"><i class="fas fa-building text-secondary"></i></span>
                    <input type="text" name="companyCode" class="form-control border-start-0 ps-0" placeholder="Örn: 1001" required autocomplete="off" />
                </div>
            </div>

            <div class="form-group mt-3 position-relative">
                <label class="form-label text-muted small fw-bold">ŞİFRE</label>
                <div class="input-group">
                    <span class="input-group-text bg-white border-end-0"><i class="fas fa-lock text-secondary"></i></span>
                    <input type="password" name="password" id="passwordInput" class="form-control border-start-0 ps-0" placeholder="******" required />

                    <span class="input-group-text bg-white cursor-pointer" style="cursor: pointer;">
                        <i class="fas fa-eye text-muted" id="togglePassword"></i>
                    </span>
                </div>
            </div>

            <button type="submit" class="btn btn-login w-100 mt-4 text-white shadow-sm">
                GÜVENLİ GİRİŞ YAP <i class="fas fa-arrow-right ms-2"></i>
            </button>
        </form>

        <div class="footer-text mt-4">
            <small>&copy; 2025 MN Software Solutions. <br> SaaS Cloud System v1.0</small>
        </div>
    </div>

    <script src="~/js/login.js"></script>

</body>
</html>